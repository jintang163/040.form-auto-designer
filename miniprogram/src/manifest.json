{
  "name": "form-auto-designer-mp",
  "appid": "__UNI__PLACEHOLDER",
  "description": "表单自动设计器小程序",
  "versionName": "1.0.0",
  "versionCode": "100",
  "transformPx": false,
  "mp-weixin": {
    "appid": "wx_placeholder_appid",
